{
  "name": "larnelleportfolio",
  "version": "0.1.0",
  "private": true,
  "rocketCritical": {
    "dependencies": [
      "next",
      "react",
      "react-dom",
      "@dhiwise/component-tagger",
      "@tailwindcss/typography",
      "recharts"
    ],
    "devDependencies": [
      "typescript",
      "@types/node",
      "@types/react",
      "@types/react-dom",
      "@typescript-eslint/eslint-plugin",
      "@typescript-eslint/parser",
      "eslint-config-next",
      "tailwindcss",
      "autoprefixer",
      "postcss",
      "eslint",
      "prettier",
      "@netlify/plugin-nextjs"
    ],
    "scripts": [
      "dev",
      "build",
      "start",
      "lint",
      "lint:fix",
      "format",
      "serve",
      "type-check"
    ],
    "warning": "🚨 CRITICAL: DO NOT REMOVE OR MODIFY ABOVE DEPENDENCIES - Required for Next.js 15 TypeScript app functionality"
  },
  "scripts": {
    "dev": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 4028",
    "build": "next build",
    "start": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 4028",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md,json}\"",
    "remotion:studio": "remotion studio remotion/index.ts",
    "remotion:render": "remotion render remotion/index.ts pale-interval-signal-loop public/assets/motion/pale-interval-signal-loop.webm --codec=vp8",
    "remotion:render:home": "remotion render remotion/index.ts home-portal-loop public/assets/motion/home-portal-loop.webm --codec=vp8",
    "remotion:render:product": "remotion render remotion/index.ts product-system-loop public/assets/motion/product-system-loop.webm --codec=vp8",
    "remotion:render:art": "remotion render remotion/index.ts art-gallery-loop public/assets/motion/art-gallery-loop.webm --codec=vp8",
    "remotion:render:literature": "remotion render remotion/index.ts pale-interval-signal-loop public/assets/motion/pale-interval-signal-loop.webm --codec=vp8",
    "remotion:render:all": "npm run remotion:render:home && npm run remotion:render:product && npm run remotion:render:art && npm run remotion:render:literature",
    "serve": "next start",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@dhiwise/component-tagger": "^1.0.15",
    "@fontsource/plus-jakarta-sans": "^5.1.0",
    "@heroicons/react": "^2.2.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@supabase/supabase-js": "^2.87.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "detect-gpu": "^5.0.70",
    "next": "15.1.11",
    "react": "19.0.3",
    "react-dom": "19.0.3",
    "recharts": "^2.15.2",
    "three": "^0.184.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@netlify/plugin-nextjs": "^5.11.1",
    "@remotion/cli": "^4.0.473",
    "@remotion/renderer": "^4.0.473",
    "@types/node": "^20",
    "@types/react": "19.0.3",
    "@types/react-dom": "19.0.3",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "autoprefixer": "10.4.2",
    "eslint": "^9",
    "eslint-config-next": "^15.2.4",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "postcss": "8.4.8",
    "prettier": "^3.5.3",
    "remotion": "^4.0.473",
    "tailwindcss": "3.4.6",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  }
}
